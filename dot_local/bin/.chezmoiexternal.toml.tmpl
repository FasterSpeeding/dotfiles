{{- $miseArch := or (and (eq .chezmoi.arch "amd64") "x64") .chezmoi.arch }}
{{- $version := printf "v%s" .miseVersion }}
{{- $archiveName := printf "mise-%s-%s-%s" $version .chezmoi.os $miseArch -}}

["mise"]
type = "file"
url = {{ gitHubReleaseAssetURL "jdx/mise" $version $archiveName | quote }}
executable = true
